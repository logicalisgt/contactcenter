    "test:coverage": "ng test --code-coverage",
    "lint": "ng lint",
    "e2e": "ng e2e",
    "serve:dist": "http-server dist -p 8080 -c-1",
    "deploy": "npm run build:prod && npm run deploy:gh-pages",
    "deploy:gh-pages": "angular-cli-ghpages --dir=dist/business-hours-override-widget"
  },
  "private": false,
  "dependencies": {
    "@angular/animations": "^12.0.0",
