{
  "name": "business-hours-override-widget",
  "version": "1.0.0",
  "description": "Webex Contact Center Supervisor Desktop Widget - Business Hours & Overrides Management",
  "author": "logicalisgt",
  "license": "MIT",
  "homepage": "https://logicalisgt.github.io/contactcenter",
  "repository": {
    "type": "git",
    "url": "https://github.com/logicalisgt/contactcenter.git"
  },
  "keywords": [
    "webex",
    "contact-center",
    "supervisor-desktop",
    "business-hours",
    "overrides",
    "angular",
    "widget"
  ],
  "scripts": {
    "ng": "ng",
    "start": "ng serve",
    "build": "ng build --configuration production --base-href=/contactcenter/",
    "build:dev": "ng build",
    "build:prod": "ng build --configuration production --base-href=/contactcenter/ --optimization",
    "build:stats": "ng build --configuration production --stats-json",
    "test": "ng test --watch=false",
    "test:watch": "ng test",
    "test:coverage": "ng test --code-coverage --watch=false",
    "lint": "ng lint",
    "e2e": "ng e2e",
    "serve:dist": "npx http-server dist/business-hours-override-widget -p 8080 -c-1",
    "analyze": "webpack-bundle-analyzer dist/business-hours-override-widget/stats.json",
    "deploy": "npm run build:prod",
    "prebuild": "npm run lint",
    "pretest": "npm run lint"
  },
  "private": false,
  "dependencies": {
    "@angular/animations": "^17.0.0",
    "@angular/common": "^17.0.0",
    "@angular/compiler": "^17.0.0",
    "@angular/core": "^17.0.0",
    "@angular/forms": "^17.0.0",
    "@angular/platform-browser": "^17.0.0",
    "@angular/platform-browser-dynamic": "^17.0.0",
    "@angular/router": "^17.0.0",
    "rxjs": "^7.8.0",
    "tslib": "^2.6.0",
    "zone.js": "^0.14.0"
  },
  "devDependencies": {
    "@angular-devkit/build-angular": "^17.0.0",
    "@angular/cli": "^17.0.0",
    "@angular/compiler-cli": "^17.0.0",
    "@types/jasmine": "~5.1.0",
    "@types/node": "^20.0.0",
    "jasmine-core": "~5.1.0",
    "karma": "~6.4.0",
    "karma-chrome-launcher": "~3.2.0",
    "karma-coverage": "~2.2.0",
    "karma-jasmine": "~5.1.0",
    "karma-jasmine-html-reporter": "~2.1.0",
    "typescript": "~5.2.0",
    "webpack-bundle-analyzer": "^4.10.0",
    "http-server": "^14.1.0",
    "@angular-eslint/builder": "^17.0.0",
    "@angular-eslint/eslint-plugin": "^17.0.0",
    "@angular-eslint/eslint-plugin-template": "^17.0.0",
    "@angular-eslint/schematics": "^17.0.0",
    "@angular-eslint/template-parser": "^17.0.0",
    "eslint": "^8.50.0"
  },
  "engines": {
    "node": ">=18.0.0",
    "npm": ">=9.0.0"
  },
  "browserslist": [
    "last 3 Chrome versions",
    "last 3 Firefox versions",
    "last 3 Safari versions",
    "last 3 Edge versions"
  ]
}
