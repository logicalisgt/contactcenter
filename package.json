  },
  "keywords": [
    "webex",
    "contact-center",
    "supervisor-desktop",
    "business-hours",
    "overrides",
    "angular",
    "widget"
  ],
  "scripts": {
    "ng": "ng",
    "start": "ng serve",
    "build": "ng build --prod --base-href=/contactcenter/",
    "build:dev": "ng build",
    "build:prod": "ng build --prod --base-href=/contactcenter/ --optimization=true",
